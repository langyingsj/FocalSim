<?xml version="1.0" encoding="utf-8"?>
<!--
    dialog_qrcode.xml - 微信群二维码弹窗 (美化版)
    替换说明：二维码图片已通过 qrcode_wechat.png 放入 res/drawable/
-->
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#E6000000">

    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center"
        android:orientation="vertical"
        android:gravity="center_horizontal">

        <!-- 顶部装饰标题 -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="24dp">

            <View
                android:layout_width="40dp"
                android:layout_height="1.5dp"
                android:background="#FFD700" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="12dp"
                android:layout_marginEnd="12dp"
                android:text="扫码加群"
                android:textColor="#FFD700"
                android:textSize="18sp"
                android:textStyle="bold"
                android:letterSpacing="0.1" />

            <View
                android:layout_width="40dp"
                android:layout_height="1.5dp"
                android:background="#FFD700" />
        </LinearLayout>

        <!-- 二维码卡片 -->
        <androidx.cardview.widget.CardView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            app:cardCornerRadius="20dp"
            app:cardElevation="12dp"
            app:cardBackgroundColor="#FFFFFF"
            app:contentPadding="28dp">

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:gravity="center_horizontal">

                <!-- 群头像和名称 -->
                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginBottom="16dp">

                    <View
                        android:layout_width="44dp"
                        android:layout_height="44dp"
                        android:background="@drawable/bg_qr_avatar"
                        android:layout_marginEnd="12dp" />

                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="浪影福利社"
                            android:textColor="#333333"
                            android:textSize="17sp"
                            android:textStyle="bold" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="2dp"
                            android:text="风光摄影交流群"
                            android:textColor="#888888"
                            android:textSize="13sp" />
                    </LinearLayout>
                </LinearLayout>

                <!-- 二维码图片 -->
                <ImageView
                    android:id="@+id/ivQrCode"
                    android:layout_width="240dp"
                    android:layout_height="240dp"
                    android:scaleType="fitCenter"
                    android:src="@drawable/qrcode_wechat"
                    android:contentDescription="浪影福利社微信群二维码" />

                <!-- 扫码提示 -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp"
                    android:text="微信扫一扫，添加我为朋友"
                    android:textColor="#999999"
                    android:textSize="13sp" />

                <!-- 功能说明标签 -->
                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:orientation="horizontal"
                    android:gravity="center">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:paddingStart="10dp"
                        android:paddingEnd="10dp"
                        android:paddingTop="4dp"
                        android:paddingBottom="4dp"
                        android:background="@drawable/bg_tag_badge"
                        android:text="摄影交流"
                        android:textColor="#FFD700"
                        android:textSize="11sp" />

                    <View android:layout_width="8dp" android:layout_height="0dp" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:paddingStart="10dp"
                        android:paddingEnd="10dp"
                        android:paddingTop="4dp"
                        android:paddingBottom="4dp"
                        android:background="@drawable/bg_tag_badge"
                        android:text="作品分享"
                        android:textColor="#FFD700"
                        android:textSize="11sp" />

                    <View android:layout_width="8dp" android:layout_height="0dp" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:paddingStart="10dp"
                        android:paddingEnd="10dp"
                        android:paddingTop="4dp"
                        android:paddingBottom="4dp"
                        android:background="@drawable/bg_tag_badge"
                        android:text="器材讨论"
                        android:textColor="#FFD700"
                        android:textSize="11sp" />
                </LinearLayout>
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- 关闭按钮 -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnCloseQr"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="28dp"
            android:text="关 闭"
            android:textColor="#FFFFFF"
            android:textSize="14sp"
            android:textStyle="bold"
            app:strokeColor="#66FFFFFF"
            app:strokeWidth="1.5dp"
            app:cornerRadius="24dp"
            app:backgroundTint="#1AFFFFFF"
            app:rippleColor="#33FFFFFF" />
    </LinearLayout>
</FrameLayout>
